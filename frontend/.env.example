# Vite environment variables — copy to .env.local for local overrides
# In production (Vercel), set VITE_API_URL to your Railway/Render backend URL

# Leave empty to use the Vite dev proxy (/api → http://localhost:8000)
VITE_API_URL=

# Production example:
# VITE_API_URL=https://gradeos-backend.up.railway.app/api
